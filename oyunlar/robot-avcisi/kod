  t(key, replacements = {}) {
    let value = (TEXT[this.currentLanguage] || TEXT.tr)[key] || TEXT.tr[key] || key;
    for (const [name, replacement] of Object.entries(replacements)) {
      value = value.replace(`{${name}}`, replacement);
